  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Ayushpython/startagram/issues"
  },
  "homepage": "https://github.com/Ayushpython/startagram#readme",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
