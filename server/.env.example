# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/idea-marketplace
MONGODB_PROD=

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# CORS — comma-separated allowed origins (leave empty for localhost defaults)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# AWS S3 (for blueprint documents)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Stripe (for payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# AI Validation Service (OpenAI or similar)
OPENAI_API_KEY=
AI_MODEL_ENDPOINT=
